<StackPanel x:Class="GameRes.Formats.GUI.WidgetYPF"
            xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            xmlns:s="clr-namespace:GameRes.Formats.Strings"
            xmlns:p="clr-namespace:GameRes.Formats.Properties"
            xmlns:gui="clr-namespace:GameRes.Formats.GUI"
            MaxWidth="250">

    <TextBox Name="SearchBox"
             Width="180"
             Margin="0,0,0,5"
             TextChanged="SearchBox_TextChanged"
             ToolTip="输入以筛选方案（不区分大小写）"/>

    <ComboBox Name="Scheme"
              Width="180"
              ItemsSource="{Binding}"
              DisplayMemberPath="Key"
              SelectedValuePath="Key"
              SelectedValue="{Binding Source={x:Static p:Settings.Default}, Path=YPFScheme, Mode=TwoWay}"/>

</StackPanel>