<Window x:Class="GameRes.Formats.BGI.KeyConflictDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BGI Key Conflict" 
        ShowInTaskbar="False" 
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" 
        SizeToContent="WidthAndHeight" 
        ShowActivated="True"
        FocusManager.FocusedElement="{Binding ElementName=KeepNewButton}"
        Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
    <StackPanel Orientation="Horizontal">
        <Image Source="actions.png" Width="64" Height="64" Margin="10"
            SnapsToDevicePixels="True" VerticalAlignment="Top" RenderOptions.BitmapScalingMode="HighQuality"/>
        <StackPanel Orientation="Vertical" Height="211">
            <TextBlock x:Name="Notice" TextWrapping="Wrap" Margin="0,10,10,10" MaxWidth="500"><Run Text="File "/><Run Text=" "/><Run x:Name="FileNameRun" FontWeight="Bold"/><Run Text=" "/><Run Text=" has a different key than previously extracted."/></TextBlock>
            <Grid Margin="0,0,10,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Existing key: " Margin="0,0,10,5"/>
                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="OldKeyText" FontFamily="Consolas" Margin="0,2,0,3"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="New key: " Margin="0,0,10,0"/>
                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="NewKeyText" FontFamily="Consolas"/>
            </Grid>
            <TextBlock Text="Which key do you want to keep?" Margin="0,0,10,10"/>
            <Separator/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button x:Name="KeepNewButton" 
                        Content="Keep New" 
                        Margin="0,10,10,10" 
                        MinWidth="75" 
                        Height="25" 
                        IsDefault="True" 
                        Click="KeepNew_Click"/>
                <Button Content="Keep Old" 
                        Margin="10" 
                        MinWidth="75" 
                        Height="25" 
                        Click="KeepOld_Click"/>
                <Button Content="Cancel" 
                        Margin="10" 
                        MinWidth="75" 
                        Height="25" 
                        IsCancel="True" 
                        Click="Cancel_Click"/>
            </StackPanel>
            <CheckBox x:Name="ApplyToAll" 
                      Content="Apply this action to all remaining conflicts" 
                      Margin="0,10,10,10"/>
        </StackPanel>
    </StackPanel>
</Window>