<Window x:Class="GameRes.Formats.Ethornell.MissingKeyDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BGI Key Not Found" 
        ShowInTaskbar="False" 
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" 
        SizeToContent="WidthAndHeight" 
        ShowActivated="True"
        FocusManager.FocusedElement="{Binding ElementName=UncompressedButton}"
        Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
    <StackPanel Orientation="Horizontal">
        <Image Source="actions.png" Width="64" Height="64" Margin="10"
            SnapsToDevicePixels="True" VerticalAlignment="Top" RenderOptions.BitmapScalingMode="HighQuality"/>
        <StackPanel Orientation="Vertical">
            <TextBlock TextWrapping="Wrap" Margin="0,10,10,10" MaxWidth="500"><Run Text="Key for file "/><Run Text=" "/><Run x:Name="FileNameRun" FontWeight="Bold"/><Run Text=" "/><Run Text=" was not found in 'bgi_keys.dat'."/></TextBlock>
            <TextBlock Text="What would you like to do?" Margin="0,0,10,10"/>
            <Separator/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button x:Name="UncompressedButton" 
                        Content="Pack Uncompressed" 
                        Margin="0,10,10,10" 
                        MinWidth="120" 
                        Height="25" 
                        IsDefault="True" 
                        Click="PackUncompressed_Click"/>
                <Button Content="Skip File" 
                        Margin="10" 
                        MinWidth="75" 
                        Height="25" 
                        Click="Skip_Click"/>
                <Button Content="Cancel All" 
                        Margin="10" 
                        MinWidth="75" 
                        Height="25" 
                        IsCancel="True" 
                        Click="Cancel_Click"/>
            </StackPanel>
            <CheckBox x:Name="ApplyToAll" 
                      Content="Apply this action to all remaining files with missing keys" 
                      Margin="0,10,10,10"/>
        </StackPanel>
    </StackPanel>
</Window>