<Grid
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:p="clr-namespace:GameRes.Formats.Properties" xmlns:av="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="av" x:Class="GameRes.Formats.GUI.CreateBGIWidget" Height="155" Width="437">
    <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
        <StackPanel Orientation="Vertical" Width="108">
            <Label Content="Archive Version:" Target="{Binding ElementName=Version}" Padding="4,0,0,5"/>
            <ComboBox x:Name="Version" Width="108" HorizontalAlignment="Left" SelectedValuePath="Content"
                      SelectedValue="{Binding BGIArchiveVersion, Mode=TwoWay, Source={x:Static p:Settings.Default}}">
                <ComboBoxItem Content="1"/>
                <ComboBoxItem Content="2"/>
            </ComboBox>
        </StackPanel>
    </StackPanel>

    <TextBlock TextWrapping="Wrap" Foreground="Black" FontSize="11.5" TextAlignment="Center" Margin="113,16,0,26"><Run Language="es-es" Text="Select &quot;2&quot; if you see &quot;BGI/Ethornell engine resource archive v2&quot; when opening one of the game's .arc files"/></TextBlock>

    <CheckBox x:Name="CompressFiles" Content="Compress files" Grid.Row="1" Margin="0,0,0,10"
              IsChecked="{Binding BGICompressFiles, Mode=TwoWay, Source={x:Static p:Settings.Default}}"/>

    <StackPanel Orientation="Horizontal" Grid.Row="2" Margin="0,5,0,12" Grid.RowSpan="2">
        <Label Content="Key file (optional):" Target="{Binding ElementName=KeyFilePath}" Padding="4,0,10,0" VerticalAlignment="Center"/>
        <TextBox x:Name="KeyFilePath" Width="175" Margin="0,0,5,0" VerticalAlignment="Center"
                 Text="{Binding BGIKeyFilePath, Mode=TwoWay, Source={x:Static p:Settings.Default}}" Height="24"/>
        <Button Content="Browse..." Click="BrowseKeyFile_Click" Padding="10,3" VerticalAlignment="Center" Width="75"/>
    </StackPanel>

    <TextBlock Grid.Row="3" TextWrapping="Wrap" Foreground="Black" FontSize="10.5" TextAlignment="Center" Margin="0,28,0,-12"><Run Text="If no key file is specified, bgi_keys.dat will be searched in the source directory."/></TextBlock>
</Grid>